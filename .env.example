# OZ Policy Builder — Environment Variables

# Required: Claude API key for AI-assisted synthesis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override default Soroban RPC URLs
SOROBAN_RPC_URL_TESTNET=https://soroban-testnet.stellar.org
SOROBAN_RPC_URL_MAINNET=https://mainnet.sorobanrpc.com

# Optional: Enable HTTP transport for MCP server (default: stdio)
OZ_POLICY_MCP_HTTP=0
OZ_POLICY_MCP_PORT=3000

# Optional: Session TTL in minutes (default: 60)
OZ_POLICY_SESSION_TTL_MINS=60
