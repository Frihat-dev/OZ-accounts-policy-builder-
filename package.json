{
  "name": "oz-policy-builder",
  "version": "0.1.0",
  "description": "AI-assisted toolkit for crafting OpenZeppelin smart account policies on Stellar",
  "type": "module",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=packages/mcp-server",
    "test": "jest --config jest.config.json",
    "test:rust": "cargo test --workspace",
    "typecheck": "npm run typecheck --workspaces",
    "mcp": "node packages/mcp-server/dist/index.js",
    "clean": "find packages -name dist -type d -exec rm -rf {} + 2>/dev/null; true"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
