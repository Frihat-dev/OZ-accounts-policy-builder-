{
  "extensionsToTreatAsEsm": [".ts"],
  "testMatch": ["**/tests/**/*.test.ts"],
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "useESM": true,
        "tsconfig": {
          "module": "NodeNext",
          "moduleResolution": "NodeNext",
          "target": "ES2022",
          "resolveJsonModule": true,
          "esModuleInterop": true
        }
      }
    ]
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "testEnvironment": "node"
}
