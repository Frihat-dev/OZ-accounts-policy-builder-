{
  "name": "@oz-policy-builder/policy-synthesizer",
  "version": "0.1.0",
  "description": "AI-assisted policy synthesis and Rust code generation for OZ Policy Builder",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
