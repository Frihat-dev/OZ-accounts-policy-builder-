  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@oz-policy-builder/tx-recorder": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
